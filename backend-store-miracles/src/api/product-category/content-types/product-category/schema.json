{
  "kind": "collectionType",
  "collectionName": "product_categories",
  "info": {
    "singularName": "product-category",
    "pluralName": "product-categories",
    "displayName": "ProductCategory"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "NombreCategoria": {
      "type": "string"
    },
    "MainImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "slug": {
      "type": "uid",
      "targetField": "NombreCategoria"
    },
    "relacionInventarioProductos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::inventario.inventario",
      "mappedBy": "product_category"
    }
  }
}
