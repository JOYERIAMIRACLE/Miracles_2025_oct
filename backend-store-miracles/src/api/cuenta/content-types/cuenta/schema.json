{
  "kind": "collectionType",
  "collectionName": "cuentas",
  "info": {
    "singularName": "cuenta",
    "pluralName": "cuentas",
    "displayName": "cuenta"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nombre": {
      "type": "string",
      "required": true
    },
    "tipo": {
      "type": "enumeration",
      "enum": [
        "Efectivo",
        "Crédito",
        "Debito"
      ]
    },
    "proposito": {
      "type": "enumeration",
      "enum": [
        "Operativa",
        "Ahorro",
        "Inversión",
        "Apartado",
        "Presupuesto 1"
      ]
    },
    "saldoInicial": {
      "type": "decimal",
      "default": 0
    },
    "metaDeCuenta": {
      "type": "decimal"
    },
    "color": {
      "type": "string"
    },
    "activa": {
      "type": "boolean",
      "default": true
    },
    "gastos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::gasto.gasto",
      "mappedBy": "cuenta"
    },
    "ventaCuenta": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::venta.venta",
      "mappedBy": "cuenta"
    }
  }
}
