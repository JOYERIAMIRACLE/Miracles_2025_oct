{
  "kind": "collectionType",
  "collectionName": "inventarios",
  "info": {
    "singularName": "inventario",
    "pluralName": "inventarios",
    "displayName": "inventario"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nombre": {
      "type": "string",
      "required": true
    },
    "sku": {
      "type": "string"
    },
    "costoProduccion": {
      "type": "decimal"
    },
    "precioVenta": {
      "type": "decimal"
    },
    "stock": {
      "type": "integer",
      "default": 0
    },
    "material": {
      "type": "enumeration",
      "enum": [
        "producto",
        "servicio"
      ]
    },
    "product_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product-category.product-category",
      "inversedBy": "relacionInventarioProductos"
    },
    "ventasInventario": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::venta.venta",
      "mappedBy": "inventario"
    }
  }
}
