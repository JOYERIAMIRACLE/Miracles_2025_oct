{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "categoria": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::product-category.product-category"
    },
    "nombreProducto": {
      "type": "string",
      "default": "SinNombre"
    },
    "descripcion": {
      "type": "text"
    },
    "slug": {
      "type": "uid"
    },
    "costo": {
      "type": "decimal"
    },
    "imagenes": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "activo": {
      "type": "boolean",
      "default": false
    },
    "materialProducto": {
      "type": "enumeration",
      "enum": [
        "Oro",
        "Plata",
        "Platino"
      ]
    },
    "isFeatured": {
      "type": "boolean"
    },
    "estiloProducto": {
      "type": "enumeration",
      "enum": [
        "Cartier",
        "Cubana",
        "China",
        "Ancla"
      ]
    },
    "detallleprod": {
      "type": "component",
      "component": "shared.cfgfg",
      "repeatable": false
    },
    "detallezonee": {
      "type": "dynamiczone",
      "components": [
        "shared.cfgfg",
        "shared.anilloss",
        "shared.cadenasss"
      ]
    }
  }
}
